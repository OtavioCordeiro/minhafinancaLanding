---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<Base
  title="Blog — Minha Finança"
  description="Dicas de finanças pessoais, organização e controle financeiro."
>
  <Navbar />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 pt-28 pb-16">
    <div class="mb-10">
      <h1 class="text-4xl font-bold text-gray-900 mb-2">Blog</h1>
      <p class="text-gray-500 text-lg">Dicas de finanças pessoais e controle financeiro</p>
    </div>

    {posts.length === 0 ? (
      <p class="text-gray-400 text-center py-16">Em breve, novos artigos por aqui.</p>
    ) : (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group block rounded-2xl border border-gray-100 hover:border-[#43BE17]/30 bg-white hover:shadow-lg transition-all p-6"
          >
            <div class="flex flex-wrap gap-1.5 mb-3">
              {post.data.tags?.map((tag) => (
                <span class="text-xs text-[#43BE17] bg-[#43BE17]/10 px-2 py-0.5 rounded-full font-medium">
                  {tag}
                </span>
              ))}
            </div>
            <h2 class="text-lg font-semibold text-gray-900 group-hover:text-[#43BE17] transition-colors mb-2 leading-snug">
              {post.data.title}
            </h2>
            <p class="text-sm text-gray-500 line-clamp-3 leading-relaxed">{post.data.description}</p>
            <p class="text-xs text-gray-400 mt-4">
              {new Intl.DateTimeFormat('pt-BR', { dateStyle: 'long' }).format(post.data.publishDate)}
            </p>
          </a>
        ))}
      </div>
    )}
  </main>

  <Footer />
</Base>
