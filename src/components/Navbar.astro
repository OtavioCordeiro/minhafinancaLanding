---
import LoginButton from './LoginButton.tsx';
---

<nav
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-10 h-16"
  style="background: rgba(255,255,255,0.75); backdrop-filter: blur(12px); border-bottom: 1px solid #E0E2E5; box-shadow: 0 1px 8px 0 rgba(0,0,0,0.04);"
>
  <!-- Logo -->
  <a href="/" class="flex items-center">
    <img src="/Logocortadaembaixo.png" alt="Minha Finança" class="h-[38px]" />
  </a>

  <!-- Links (desktop) -->
  <div class="hidden md:flex items-center gap-7">
    <a href="/#recursos" class="text-sm font-medium text-gray-600 hover:text-[#43BE17] transition-colors">Recursos</a>
    <a href="/#planos" class="text-sm font-medium text-gray-600 hover:text-[#43BE17] transition-colors">Planos</a>
    <a href="/#depoimentos" class="text-sm font-medium text-gray-600 hover:text-[#43BE17] transition-colors">Depoimentos</a>
    <a href="/#faq" class="text-sm font-medium text-gray-600 hover:text-[#43BE17] transition-colors">FAQ</a>
    <a href="/blog" class="text-sm font-medium text-gray-600 hover:text-[#43BE17] transition-colors">Blog</a>
    <a href="/ajuda" class="text-sm font-medium text-gray-600 hover:text-[#43BE17] transition-colors">Ajuda</a>
  </div>

  <!-- Login button (React island) -->
  <LoginButton client:load />
</nav>
