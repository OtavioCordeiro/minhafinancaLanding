# URL do backend usada pelo proxy Vite (não exposta ao browser)
BACKEND_TARGET=https://localhost:7182

# URL da API do backend (pública — prefixo PUBLIC_ expõe ao browser no Astro)
# Deixe vazio para usar proxy do Vite (dev local)
# Preencha com a URL real em produção
PUBLIC_API_URL=https://localhost:7182

# URL do app autenticado (React frontend)
# Dev local: http://localhost:5173
# Produção: https://app.minhafinanca.com.br
PUBLIC_APP_URL=http://localhost:5173

# Google OAuth Client ID (mesmo valor do frontend)
PUBLIC_GOOGLE_CLIENT_ID=171068598274-fnsq2v15lfv205f4c0ivkgbr5fn3mj2h.apps.googleusercontent.com
